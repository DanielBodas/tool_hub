# -----------------------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Production URL (e.g., https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AUTHENTICATION PROVIDERS
# -----------------------------------------------------------------------------
# Google OAuth - Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# SECURITY & ACCESS CONTROL
# -----------------------------------------------------------------------------
# Primary Admin Access Code (Credentials Login)
ADMIN_CODE=admin123

# Secondary Validation PIN for Dashboard
ADMIN_PIN=1234

# Tool-Specific PINs (Granular Access)
# Format: [TOOL_ID_IN_UPPERCASE]_PIN
FINANCE_TRACKER_PIN=5555
TOOL_ONE_PIN=1111
TOOL_TWO_PIN=2222
