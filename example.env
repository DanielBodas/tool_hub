# -----------------------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Production URL (e.g., https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AUTHENTICATION PROVIDERS
# -----------------------------------------------------------------------------
# Google OAuth - Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# HUB ACCESS CONTROL (PIN/CODE)
# -----------------------------------------------------------------------------
# If NOT SET, the default pin for everything is '1234'
# Admin Code / Dashboard access code
ADMIN_CODE=1234

# -----------------------------------------------------------------------------
# Tool-specific PINs have been moved to their respective src/modules/<tool>/example.env files.
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Connection string: mongodb+srv://<db_username>:<db_password>@cluster0.ge3cmmu.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb://localhost:27017/platform-db
